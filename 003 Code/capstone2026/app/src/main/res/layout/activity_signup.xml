<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentLeft="true"
                android:background="?android:attr/actionModeCloseDrawable"
                android:backgroundTint="@color/brown_dark" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="회원가입"
            android:textColor="@color/brown_dark"
            android:textSize="30sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editSignupId"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="50dp"
            android:backgroundTint="@color/brown_light"
            android:hint="이메일 주소 (아이디)"
            android:inputType="textEmailAddress"
            android:padding="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/brown_light" />

        <EditText
            android:id="@+id/editSignupPassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/brown_light"
            android:hint="비밀번호"
            android:inputType="textPassword"
            android:padding="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/brown_light" />

        <EditText
            android:id="@+id/editSignupPasswordCheck"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/brown_light"
            android:hint="비밀번호 확인"
            android:inputType="textPassword"
            android:padding="14dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/brown_light" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/rounded_brown_button"
            android:text="가입하기"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnBackLogin"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/rounded_brown_button"
            android:text="로그인으로 돌아가기"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/btnFindPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            android:padding="10dp"
            android:text="비밀번호를 잊으셨나요? (비밀번호 찾기)"
            android:textColor="@color/brown_dark"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground" />

    </LinearLayout>

</ScrollView>