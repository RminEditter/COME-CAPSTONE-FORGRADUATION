<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_home_card"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/tvCafeName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="카페 이름"
        android:textColor="@color/brown_dark"
        android:textSize="19sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="별점: 5.0"
        android:textColor="@color/brown_light"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMemo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="5dp"
        android:text="메모: 방문 메모"
        android:textColor="@color/text_dark"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="방문일: 2026-05-07"
        android:textColor="#8B7768"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="클릭해서 수정 · 길게 눌러 삭제"
        android:textColor="#A89788"
        android:textSize="12sp" />

</LinearLayout>